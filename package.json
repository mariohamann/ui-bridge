{
  "name": "ui-bridge",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @ui-bridge/docs dev",
    "dev:vite": "pnpm --filter ui-bridge-demo-vite dev",
    "dev:webpack": "pnpm --filter ui-bridge-demo-webpack dev",
    "dev:rspack": "pnpm --filter ui-bridge-demo-rspack dev",
    "dev:astro": "pnpm --filter ui-bridge-demo-astro dev",
    "dev:next": "pnpm --filter ui-bridge-demo-next dev",
    "dev:nuxt": "pnpm --filter ui-bridge-demo-nuxt dev",
    "docs:build": "pnpm --filter @ui-bridge/docs build",
    "build": "pnpm -r build",
    "build:core": "pnpm --filter \"./core/**\" build",
    "build:integrations": "pnpm --filter \"./integrations/**\" build",
    "build:demos": "pnpm --filter \"./demos/**\" build",
    "typecheck": "pnpm -r --parallel typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm format:check && pnpm typecheck && pnpm build && pnpm test",
    "test": "pnpm build:core && pnpm build:integrations && SKIP_BUILD=true pnpm -r --workspace-concurrency=4 run test",
    "test:core": "pnpm build:core && SKIP_BUILD=true pnpm --filter \"./core/**\" test",
    "test:integrations": "pnpm build:core && pnpm build:integrations && SKIP_BUILD=true pnpm --filter \"./integrations/**\" test",
    "test:client": "pnpm --filter @ui-bridge/client test",
    "test:components": "pnpm --filter @ui-bridge/components test",
    "test:protocol": "pnpm --filter @ui-bridge/protocol test",
    "test:server": "pnpm --filter @ui-bridge/server test"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "wireit": "^0.14.12"
  }
}

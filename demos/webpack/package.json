{
  "name": "ui-bridge-demo-webpack",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wireit",
    "build": "webpack --mode production"
  },
  "wireit": {
    "dev": {
      "command": "webpack serve",
      "service": {
        "readyWhen": {
          "lineMatches": "compiled|Loopback:"
        }
      },
      "dependencies": [
        "../../integrations/unplugin:dev"
      ],
      "files": [
        "src/**",
        "webpack.config.*"
      ]
    }
  },
  "dependencies": {
    "@picocss/pico": "^2.0.0",
    "@ui-bridge/demo-styles": "workspace:*"
  },
  "devDependencies": {
    "@ui-bridge/unplugin": "workspace:*",
    "css-loader": "^7.0.0",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.0",
    "webpack-dev-server": "^5.2.2"
  }
}

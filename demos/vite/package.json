{
  "name": "ui-bridge-demo-vite",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wireit",
    "build": "vite build",
    "preview": "vite preview"
  },
  "wireit": {
    "dev": {
      "command": "vite dev",
      "service": {
        "readyWhen": {
          "lineMatches": "Local\\s+http://localhost"
        }
      },
      "dependencies": [
        "../../integrations/unplugin:dev"
      ],
      "files": [
        "src/**",
        "vite.config.*",
        "index.html"
      ]
    }
  },
  "dependencies": {
    "@ui-bridge/demo-styles": "workspace:*",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@ui-bridge/unplugin": "workspace:*",
    "@playwright/test": "^1.50.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^6.0.0"
  }
}

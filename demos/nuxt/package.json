{
  "name": "design-bridge-demo-nuxt",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wireit",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview"
  },
  "wireit": {
    "dev": {
      "command": "nuxt dev",
      "service": {
        "readyWhen": {
          "lineMatches": "Nuxt\\s+\\d|Local\\s+http://localhost"
        }
      },
      "dependencies": [
        "../../integrations/nuxt:build"
      ],
      "files": [
        "src/**",
        "nuxt.config.*",
        "app.vue"
      ]
    }
  },
  "dependencies": {
    "@picocss/pico": "^2.0.0",
    "nuxt": "^3.16.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@design-bridge/nuxt": "workspace:*"
  }
}

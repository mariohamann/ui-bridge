{
  "name": "design-bridge-demo-next",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wireit",
    "build": "next build",
    "start": "next start"
  },
  "wireit": {
    "dev": {
      "command": "next dev --turbo",
      "service": {
        "readyWhen": {
          "lineMatches": "Local\\s+http://localhost|Ready in"
        }
      },
      "dependencies": [
        "../../integrations/next:build"
      ],
      "files": [
        "app/**",
        "components/**",
        "next.config.*"
      ]
    }
  },
  "dependencies": {
    "@picocss/pico": "^2.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@design-bridge/next": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "~6.0.2"
  }
}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Luminary — Design Bridge Astro Demo</title>
  </head>
  <body>
    <AppNav />
    <main>
      <HeroSection />
      <FeaturesSection />
      <CtaSection />
    </main>
    <AppFooter />
  </body>
</html>

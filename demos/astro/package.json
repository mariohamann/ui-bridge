{
  "name": "design-bridge-demo-astro",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "wireit",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "wireit": {
    "dev": {
      "command": "astro dev",
      "service": {
        "readyWhen": {
          "lineMatches": "Local\\s+http://localhost"
        }
      },
      "dependencies": [
        "../../integrations/astro:dev"
      ],
      "files": [
        "src/**",
        "astro.config.*"
      ]
    }
  },
  "dependencies": {
    "@design-bridge/demo-styles": "workspace:*",
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "@design-bridge/astro": "workspace:*"
  }
}

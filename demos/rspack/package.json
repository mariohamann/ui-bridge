{
  "name": "ui-bridge-demo-rspack",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wireit",
    "build": "rspack build"
  },
  "wireit": {
    "dev": {
      "command": "rspack serve",
      "service": {
        "readyWhen": {
          "lineMatches": "compiled|Loopback:"
        }
      },
      "dependencies": [
        "../../integrations/unplugin:dev"
      ],
      "files": [
        "src/**",
        "rspack.config.*"
      ]
    }
  },
  "dependencies": {
    "@picocss/pico": "^2.0.0"
  },
  "devDependencies": {
    "@ui-bridge/unplugin": "workspace:*",
    "@rspack/cli": "^1.3.13",
    "@rspack/core": "^1.3.13",
    "css-loader": "^7.0.0",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0"
  }
}

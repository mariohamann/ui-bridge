{
  "name": "@ui-bridge/astro",
  "version": "1.0.0",
  "description": "Astro integration for UI Bridge",
  "license": "MIT",
  "homepage": "https://ui-bridge.mariohamann.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/mariohamann/ui-bridge",
    "directory": "integrations/astro"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "wireit",
    "dev": "wireit",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "playwright test",
    "prepublishOnly": "pnpm build"
  },
  "wireit": {
    "build": {
      "command": "node build.mjs",
      "dependencies": [
        "../../integrations/unplugin:build"
      ],
      "files": [
        "src/**/*.ts",
        "build.mjs",
        "tsconfig.build.json"
      ],
      "output": [
        "dist/**"
      ]
    },
    "dev": {
      "command": "node build.mjs --watch",
      "service": {
        "readyWhen": {
          "lineMatches": "watching for changes"
        }
      },
      "dependencies": [
        "../../integrations/unplugin:dev"
      ],
      "files": [
        "src/**/*.ts",
        "build.mjs",
        "tsconfig.build.json"
      ]
    }
  },
  "dependencies": {
    "@ui-bridge/mcp": "workspace:*",
    "@ui-bridge/protocol": "workspace:*",
    "@ui-bridge/unplugin": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.6.0",
    "astro": "^6.3.1",
    "esbuild": "^0.25.0",
    "typescript": "~6.0.2"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

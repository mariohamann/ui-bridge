{
  "name": "@design-bridge/nuxt",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "wireit",
    "dev": "wireit",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "playwright test"
  },
  "wireit": {
    "build": {
      "command": "node build.mjs",
      "dependencies": [
        "../../integrations/unplugin:build"
      ],
      "files": [
        "src/**/*.ts",
        "build.mjs",
        "tsconfig.build.json"
      ],
      "output": [
        "dist/**"
      ]
    },
    "dev": {
      "command": "node build.mjs --watch",
      "service": {
        "readyWhen": {
          "lineMatches": "watching for changes"
        }
      },
      "dependencies": [
        "../../integrations/unplugin:dev"
      ],
      "files": [
        "src/**/*.ts",
        "build.mjs",
        "tsconfig.build.json"
      ]
    }
  },
  "dependencies": {
    "@design-bridge/mcp": "workspace:*",
    "@design-bridge/unplugin": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@nuxt/kit": "^3.16.0",
    "@nuxt/schema": "^3.16.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.0",
    "typescript": "~6.0.2"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0"
  }
}

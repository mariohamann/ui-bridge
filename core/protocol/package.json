{
  "name": "@design-bridge/protocol",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "wireit",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "wireit": {
    "build": {
      "command": "tsc -p tsconfig.json",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": [
        "dist/**"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}

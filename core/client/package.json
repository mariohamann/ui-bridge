{
  "name": "@design-bridge/client",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/design-bridge.js",
  "exports": {
    ".": "./dist/design-bridge.js",
    "./review-page": "./dist/review-page.js"
  },
  "scripts": {
    "build": "wireit",
    "dev": "wireit",
    "test": "playwright test"
  },
  "wireit": {
    "build": {
      "command": "node build.mjs",
      "dependencies": [
        "../components:build"
      ],
      "files": [
        "src/**/*.ts",
        "build.mjs"
      ],
      "output": [
        "dist/**"
      ]
    },
    "dev": {
      "command": "node build.mjs --watch",
      "service": {
        "readyWhen": {
          "lineMatches": "watching for changes"
        }
      },
      "dependencies": [
        "../components:dev"
      ],
      "files": [
        "src/**/*.ts",
        "build.mjs"
      ]
    }
  },
  "devDependencies": {
    "@awesome.me/webawesome": "^3.7.0",
    "@design-bridge/components": "workspace:*",
    "@design-bridge/protocol": "workspace:*",
    "@floating-ui/dom": "^1.7.6",
    "@lit-labs/signals": "^0.2.0",
    "@medv/finder": "^4.0.2",
    "@playwright/test": "^1.50.0",
    "@types/autosize": "^4.0.3",
    "@types/node": "^25.6.0",
    "autosize": "^6.0.1",
    "esbuild": "^0.25.0",
    "lit": "^3.3.0",
    "signal-polyfill": "^0.2.2",
    "typescript": "~6.0.2"
  }
}

---
export interface Props {
  url?: string
  class?: string
}
const { url = "localhost:5173", class: cls = "" } = Astro.props
---

<div class:list={["browser-frame", cls]}>
  <div class="browser-bar">
    <div class="flex gap-1.5">
      <span class="browser-dot browser-dot-red"></span>
      <span class="browser-dot browser-dot-amber"></span>
      <span class="browser-dot browser-dot-green"></span>
    </div>
    <div class="browser-url">{url}</div>
  </div>
  <div class="relative overflow-hidden">
    <slot />
  </div>
</div>

#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/mario.hamann/Documents/GitHub/solid-mcp-demo/packages/server/node_modules:/Users/mario.hamann/Documents/GitHub/solid-mcp-demo/packages/node_modules:/Users/mario.hamann/Documents/GitHub/solid-mcp-demo/node_modules:/Users/mario.hamann/Documents/GitHub/node_modules:/Users/mario.hamann/Documents/node_modules:/Users/mario.hamann/node_modules:/Users/node_modules:/node_modules:/Users/mario.hamann/Documents/GitHub/solid-mcp-demo/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/mario.hamann/Documents/GitHub/solid-mcp-demo/packages/server/node_modules:/Users/mario.hamann/Documents/GitHub/solid-mcp-demo/packages/node_modules:/Users/mario.hamann/Documents/GitHub/solid-mcp-demo/node_modules:/Users/mario.hamann/Documents/GitHub/node_modules:/Users/mario.hamann/Documents/node_modules:/Users/mario.hamann/node_modules:/Users/node_modules:/node_modules:/Users/mario.hamann/Documents/GitHub/solid-mcp-demo/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@design-bridge/server/index.mjs" "$@"
else
  exec node  "$basedir/../@design-bridge/server/index.mjs" "$@"
fi

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/node",
    "rootDir": "./src",
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["src/node/**/*", "src/shared/**/*"],
  "exclude": ["src/browser/**/*"]
}

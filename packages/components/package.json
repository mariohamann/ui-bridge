  },
  "dependencies": {
    "@awesome.me/webawesome": "^3.6.0",
    "@design-bridge/core": "workspace:*",
    "@floating-ui/dom": "^1.7.6",
    "autosize": "^6.0.1",
    "@lit-labs/signals": "^0.2.0",
    "lit": "^3.3.0",
    "signal-polyfill": "^0.2.2"
  },
  "devDependencies": {
    "@types/autosize": "^4.0.3",
    "typescript": "~6.0.2"
  }
}

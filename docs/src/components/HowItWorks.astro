---
const steps = [
  {
    title: 'Select an element',
    description:
      'Hold Alt and click any element in your browser. A comment thread opens attached to that element.',
  },
  {
    title: 'Write a comment',
    description:
      'Describe what you want to change. The comment is stored locally and surfaced to your agent through the MCP server.',
  },
  {
    title: 'Get a live tweak',
    description:
      'The agent can reply with a knob — a live control that updates your source file on the fly so you can try values without switching to an editor.',
  },
  {
    title: 'Accept or discard',
    description:
      'Keep the change by accepting it — the file is updated permanently. Discard to restore the original. Either way the thread stays as a record.',
  },
];
---

<script>
  import '@awesome.me/webawesome/dist/components/badge/badge.js';
</script>

<section id="how-it-works" class="bg-wa-surface-raised px-6 py-20">
  <div class="mx-auto max-w-[640px]">
    <h2>How it works</h2>

    <p>
      Design Bridge sits between your running UI and your AI agent. You leave feedback directly on
      the page, the agent reads it via MCP, and changes land in your source files.
    </p>

    <ol class="mt-8 space-y-6">
      {
        steps.map((step, i) => (
          <li class="flex gap-6">
            <div>
              <wa-badge variant="neutral" size="m">
                {i + 1}
              </wa-badge>
            </div>
            <div>
              <p class="font-medium">{step.title}</p>
              <p class="mt-1 text-wa-text-quiet">{step.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

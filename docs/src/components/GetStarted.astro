---
import { Code } from 'astro:components';

const installUnplugin = `# pnpm
pnpm add -D @ui-bridge/unplugin
# npm
npm install --save-dev @ui-bridge/unplugin
# yarn
yarn add -D @ui-bridge/unplugin`;

const installNext = `# pnpm
pnpm add -D @ui-bridge/next
# npm
npm install --save-dev @ui-bridge/next
# yarn
yarn add -D @ui-bridge/next`;

const installNuxt = `# pnpm
pnpm add -D @ui-bridge/nuxt
# npm
npm install --save-dev @ui-bridge/nuxt
# yarn
yarn add -D @ui-bridge/nuxt`;

const installAstro = `# pnpm
pnpm add -D @ui-bridge/astro
# npm
npm install --save-dev @ui-bridge/astro
# yarn
yarn add -D @ui-bridge/astro`;

const configVite = `import { defineConfig } from 'vite'
import { uiBridgeVite } from '@ui-bridge/unplugin'

export default defineConfig({
  plugins: [...uiBridgeVite()]
})`;

const configNext = `import { withUiBridge } from '@ui-bridge/next'

export default withUiBridge({
  // your Next.js config
})`;

const configNuxt = `export default defineNuxtConfig({
  modules: ['@ui-bridge/nuxt']
})`;

const configAstro = `import { defineConfig } from 'astro/config'
import uiBridge from '@ui-bridge/astro'

export default defineConfig({
  integrations: [uiBridge()]
})`;

const sourceAnnotationHtmlComments = `import { defineConfig } from 'vite'
import { uiBridgeVite } from '@ui-bridge/unplugin'

export default defineConfig({
  plugins: [
    ...uiBridgeVite({
      inspector: false,
      sourceAnnotation: {
        // Each entry is a regex. Capture group 1 is the file path.
        // List multiple patterns if you mix frameworks — first match wins.
        htmlComments: [
          { pattern: 'Start view: (.+?\.blade\.php)' },
        ],
      },
    }),
  ],
})`;

const sourceAnnotationDataAttribute = `import { defineConfig } from 'vite'
import { uiBridgeVite } from '@ui-bridge/unplugin'

export default defineConfig({
  plugins: [
    ...uiBridgeVite({
      sourceAnnotation: {
        // Single attribute encoding "file:line:col"
        dataAttributes: [{ pathAttr: 'data-source' }],
        // Or split across two attributes:
        // dataAttributes: [{ fileAttr: 'data-file', locAttr: 'data-loc' }],
      },
    }),
  ],
})`;
---

<script>
  import '@awesome.me/webawesome/dist/components/tab-group/tab-group.js';
  import '@awesome.me/webawesome/dist/components/tab/tab.js';
  import '@awesome.me/webawesome/dist/components/tab-panel/tab-panel.js';
</script>

<section id="get-started" class="bg-wa-surface-default px-6 py-20">
  <div class="mx-auto max-w-[640px]">
    <h2>Setup</h2>

    <p>Install the package for your framework, add it to your config, and run your dev server.</p>

    <wa-tab-group class="mb-9">
      <wa-tab panel="vite">Vite</wa-tab>
      <wa-tab panel="next">Next.js</wa-tab>
      <wa-tab panel="nuxt">Nuxt</wa-tab>
      <wa-tab panel="astro">Astro</wa-tab>

      <wa-tab-panel name="vite">
        <div class="code-block mb-3">
          <div class="code-block-header"><span class="code-block-filename">terminal</span></div>
          <Code code={installUnplugin} lang="sh" theme="github-dark" />
        </div>
        <div class="code-block">
          <div class="code-block-header">
            <span class="code-block-filename">vite.config.ts</span>
          </div>
          <Code code={configVite} lang="ts" theme="github-dark" />
        </div>
      </wa-tab-panel>

      <wa-tab-panel name="next">
        <div class="code-block mb-3">
          <div class="code-block-header"><span class="code-block-filename">terminal</span></div>
          <Code code={installNext} lang="sh" theme="github-dark" />
        </div>
        <div class="code-block">
          <div class="code-block-header">
            <span class="code-block-filename">next.config.mjs</span>
          </div>
          <Code code={configNext} lang="js" theme="github-dark" />
        </div>
      </wa-tab-panel>

      <wa-tab-panel name="nuxt">
        <div class="code-block mb-3">
          <div class="code-block-header"><span class="code-block-filename">terminal</span></div>
          <Code code={installNuxt} lang="sh" theme="github-dark" />
        </div>
        <div class="code-block">
          <div class="code-block-header">
            <span class="code-block-filename">nuxt.config.ts</span>
          </div>
          <Code code={configNuxt} lang="ts" theme="github-dark" />
        </div>
      </wa-tab-panel>

      <wa-tab-panel name="astro">
        <div class="code-block mb-3">
          <div class="code-block-header"><span class="code-block-filename">terminal</span></div>
          <Code code={installAstro} lang="sh" theme="github-dark" />
        </div>
        <div class="code-block">
          <div class="code-block-header">
            <span class="code-block-filename">astro.config.mjs</span>
          </div>
          <Code code={configAstro} lang="js" theme="github-dark" />
        </div>
      </wa-tab-panel>
    </wa-tab-group>

    <p>Run your dev server. The panel appears in your browser.</p>

    <h3>Custom source location</h3>

    <p>
      Source location is detected automatically. If your stack doesn't support it — or you want to
      override it — you can read it from HTML comments or data attributes in the rendered markup.
    </p>

    <p>
      <strong>HTML comments</strong> — use <code>htmlComments</code> with a regex pattern. Useful for
      frameworks like Laravel Blade with <a
        href="https://github.com/pixelfear/laravel-view-debug"
        target="_blank"
        rel="noopener">laravel-view-debug</a
      > that wrap partials in comments like
      <code>&lt;!-- Start view: /path/to/file.blade.php --&gt;</code>. Set
      <code>inspector: false</code> when code-inspector can't annotate your templates:
    </p>

    <div class="code-block mb-6">
      <div class="code-block-header">
        <span class="code-block-filename">vite.config.ts</span>
      </div>
      <Code code={sourceAnnotationHtmlComments} lang="ts" theme="github-dark" />
    </div>

    <p>
      <strong>Data attributes</strong> — use <code>dataAttributes</code> if your build pipeline stamps
      location onto elements. Supports a single <code>file:line:col</code> attribute or separate file
      and location attributes:
    </p>

    <div class="code-block mb-9">
      <div class="code-block-header">
        <span class="code-block-filename">vite.config.ts</span>
      </div>
      <Code code={sourceAnnotationDataAttribute} lang="ts" theme="github-dark" />
    </div>
  </div>
</section>

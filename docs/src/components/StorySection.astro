---
import BrowserFrame from "./BrowserFrame.astro"
---

<section id="story" class="bg-db-bg">
  <div id="story-inner" class="mx-auto grid max-w-[1200px] grid-cols-2">
    <!-- ── LEFT: scrolling narrative ─────────────────────────────────────── -->
    <div id="story-left" class="px-6 pl-6 pr-12">
      <!-- Step 1 -->
      <div
        class="story-step flex min-h-screen flex-col justify-center py-20"
        data-step="1"
      >
        <p class="section-label section-label-accent">The problem</p>
        <h2
          class="mb-6 text-[clamp(28px,3vw,42px)] font-semibold leading-[1.15] tracking-tight"
        >
          "Which element?"
        </h2>
        <div
          class="max-w-[400px] space-y-4 text-[17px] leading-relaxed text-db-muted"
        >
          <p>You see something in the browser.<br />Your agent doesn't.</p>
          <p>
            You describe it. It guesses.<br />Gets it wrong. You describe again.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div
        class="story-step flex min-h-screen flex-col justify-center py-20"
        data-step="2"
      >
        <p class="section-label section-label-accent">The fix</p>
        <h2
          class="mb-6 text-[clamp(28px,3vw,42px)] font-semibold leading-[1.15] tracking-tight"
        >
          Alt+Shift+click anything.
        </h2>
        <div
          class="mb-7 max-w-[400px] space-y-4 text-[17px] leading-relaxed text-db-muted"
        >
          <p>
            Click any element. Design Bridge captures the CSS selector, the
            source file, and the line number.
          </p>
          <p>
            Add a comment. Your agent now knows <em class="text-db-text"
              >exactly</em
            > what you meant.
          </p>
        </div>
        <div class="flex flex-col gap-2.5">
          <div class="check-item">
            <span class="check-icon">✓</span>Stable CSS selector via <code
              class="text-db-dim">@medv/finder</code>
          </div>
          <div class="check-item">
            <span class="check-icon">✓</span>Source file + line from
            code-inspector (optional)
          </div>
          <div class="check-item">
            <span class="check-icon">✓</span>Persisted as JSON, synced via
            WebSocket
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div
        class="story-step flex min-h-screen flex-col justify-center py-20"
        data-step="3"
      >
        <p class="section-label section-label-amber">The problem</p>
        <h2
          class="mb-6 text-[clamp(28px,3vw,42px)] font-semibold leading-[1.15] tracking-tight"
        >
          "Is this right?"
        </h2>
        <div
          class="max-w-[400px] space-y-4 text-[17px] leading-relaxed text-db-muted"
        >
          <p>
            Your agent changes something. You wait for the rebuild. It's
            slightly off.
          </p>
          <p>
            You explain again. You wait again.<br /><em class="text-db-amber"
              >Four round-trips for a font size.</em>
          </p>
        </div>
      </div>

      <!-- Step 4 -->
      <div
        class="story-step flex min-h-screen flex-col justify-center py-20"
        data-step="4"
      >
        <p class="section-label section-label-accent">The fix</p>
        <h2
          class="mb-6 text-[clamp(28px,3vw,42px)] font-semibold leading-[1.15] tracking-tight"
        >
          Your agent creates knobs.
        </h2>
        <div
          class="mb-7 max-w-[400px] space-y-4 text-[17px] leading-relaxed text-db-muted"
        >
          <p>No rebuild. No waiting. Drag until it's right.</p>
          <p>
            Hit <strong class="text-db-text">Finalize</strong> — Design Bridge writes
            the value permanently to your source file.
          </p>
        </div>
        <div class="flex flex-col gap-2.5">
          <div class="check-item">
            <span class="check-icon">✓</span>Number · Color · Text · Boolean ·
            Select · Button-group
          </div>
          <div class="check-item">
            <span class="check-icon">✓</span>Snapshot/replay — safe to compose,
            always reversible
          </div>
          <div class="check-item">
            <span class="check-icon">✓</span>Writes to source on Finalize —
            reset restores original
          </div>
        </div>
      </div>

      <!-- Step 5 -->
      <div
        class="story-step flex min-h-screen flex-col justify-center py-20"
        data-step="5"
      >
        <p class="section-label section-label-accent">The full loop</p>
        <h2
          class="mb-6 text-[clamp(28px,3vw,42px)] font-semibold leading-[1.15] tracking-tight"
        >
          Humans stay in the browser.<br />Agents stay in context.
        </h2>
        <p class="mb-7 text-[17px] leading-relaxed text-db-muted">
          Nothing gets lost in translation.
        </p>
        <div class="flex flex-col gap-1.5 text-sm">
          <span class="text-db-accent">You annotate</span>
          <span class="pl-3 text-db-subtle">↓</span>
          <span class="text-db-dim"
            >Agent reads — full element + source context</span
          >
          <span class="pl-3 text-db-subtle">↓</span>
          <span class="text-db-dim"
            >Agent creates tweaks — knobs appear in your browser</span
          >
          <span class="pl-3 text-db-subtle">↓</span>
          <span class="text-db-dim">You pick what looks right</span>
          <span class="pl-3 text-db-subtle">↓</span>
          <span class="text-db-green">Design Bridge writes to source ✓</span>
        </div>
      </div>
    </div><!-- /story-left -->

    <!-- ── RIGHT: pinned browser window ──────────────────────────────────── -->
    <div
      id="story-right"
      class="sticky top-0 flex h-screen items-center justify-center py-10 pr-6 pl-0"
    >
      <div class="w-full max-w-[480px]">
        <BrowserFrame>
          <div
            id="scene-container"
            class="relative h-[420px] overflow-hidden bg-db-bg"
          >
            <!-- Base app UI (always visible underneath scenes) -->
            <div id="fake-app-ui" class="flex flex-col gap-2.5 p-[18px]">
              <!-- Nav bar -->
              <div
                class="flex items-center gap-2.5 rounded-lg border border-db-border bg-db-surface px-3.5 py-2.5"
              >
                <div class="size-3.5 flex-shrink-0 rounded bg-db-accent"></div>
                <div class="h-[5px] w-11 rounded bg-db-card"></div>
                <div class="flex-1"></div>
                <div class="h-[5px] w-8 rounded bg-db-border"></div>
                <div class="h-[5px] w-8 rounded bg-db-border"></div>
              </div>
              <!-- Cards -->
              <div class="grid grid-cols-2 gap-2.5">
                <div
                  id="demo-card-1"
                  class="rounded-lg border border-db-border bg-db-surface p-3.5 transition-all duration-200"
                >
                  <div class="mb-2.5 h-1.5 w-14 rounded bg-db-card"></div>
                  <div
                    id="demo-card-text"
                    class="mb-3 text-[10px] leading-relaxed text-db-muted"
                  >
                    Card content
                  </div>
                  <div
                    id="demo-btn"
                    class="inline-block cursor-default rounded-md bg-db-accent px-3 py-1.5 text-[10px] text-white transition-all duration-200"
                  >
                    Action
                  </div>
                </div>
                <div
                  class="rounded-lg border border-db-border bg-db-surface p-3.5"
                >
                  <div class="mb-2.5 h-1.5 w-10 rounded bg-db-card"></div>
                  <div class="mb-3 text-[10px] leading-relaxed text-db-muted">
                    Another card
                  </div>
                  <div
                    class="inline-block rounded-md border border-db-border px-3 py-1.5 text-[10px] text-db-muted"
                  >
                    Browse
                  </div>
                </div>
              </div>
              <!-- Footer bar -->
              <div
                class="flex items-center gap-2 rounded-md border border-db-border bg-db-bg px-3 py-2"
              >
                <div class="h-1 w-6 rounded bg-db-border"></div>
                <div class="h-1 w-11 rounded bg-db-border"></div>
                <div class="flex-1"></div>
                <div class="h-1 w-6 rounded bg-db-border"></div>
              </div>
            </div>

            <!-- ── Scene 1: frustrated chat bubbles ─────────────────────── -->
            <div
              id="scene-1"
              class="scene pointer-events-none absolute inset-x-0 bottom-0 hidden p-4"
            >
              <div class="ml-auto flex max-w-[190px] flex-col gap-1.5">
                <div
                  class="chat-bubble rounded-lg rounded-br-sm border border-[#2a2a4e] bg-[#1a1a2e] px-2.5 py-1.5 text-[10px] text-db-muted opacity-0"
                >
                  "make the card bigger"
                </div>
                <div
                  class="chat-bubble rounded-lg rounded-br-sm border border-[#2a2a4e] bg-[#1a1a2e] px-2.5 py-1.5 text-[10px] text-db-muted opacity-0"
                >
                  "no, the other one"
                </div>
                <div
                  class="chat-bubble rounded-lg rounded-br-sm border border-[#2a2a4e] bg-[#1a1a2e] px-2.5 py-1.5 text-[10px] text-db-muted opacity-0"
                >
                  "the blue bordered one 😤"
                </div>
              </div>
            </div>

            <!-- ── Scene 2: annotation appearing ───────────────────────── -->
            <div
              id="scene-2"
              class="scene pointer-events-none absolute inset-0 hidden"
            >
              <!-- animated cursor (triangle via borders) -->
              <div
                id="anim-cursor"
                class="absolute z-50 opacity-0 transition-[top,left] duration-700"
                style="top:35%;left:20%;width:0;height:0;border-left:9px solid white;border-top:5px solid transparent;border-bottom:5px solid transparent;filter:drop-shadow(0 1px 3px rgba(0,0,0,.9));"
              >
              </div>
              <!-- badge -->
              <div
                id="anim-badge"
                class="absolute opacity-0"
                style="top:128px;left:22px;"
              >
                <div
                  class="flex size-[18px] items-center justify-center rounded-full bg-db-accent text-[9px] font-bold text-white"
                  style="box-shadow:0 2px 8px rgba(124,109,250,.6);"
                >
                  1
                </div>
              </div>
              <!-- annotation panel -->
              <div
                id="anim-panel"
                class="absolute rounded-xl border border-db-border bg-db-surface p-3 opacity-0"
                style="top:94px;left:48px;width:190px;box-shadow:0 8px 24px rgba(0,0,0,.8);"
              >
                <p class="mb-1 text-[9px] text-db-muted">
                  <span class="text-db-accent">●</span> src/components/Card.tsx:42
                </p>
                <p class="mb-1.5 text-[10px] leading-relaxed text-db-text">
                  "Button padding too tight on mobile"
                </p>
                <p class="font-mono text-[8px] text-db-subtle">
                  .card &gt; button
                </p>
              </div>
            </div>

            <!-- ── Scene 3: terminal flicker ────────────────────────────── -->
            <div
              id="scene-3"
              class="scene absolute inset-0 hidden items-center justify-center bg-black/[.88]"
            >
              <div class="p-5 font-mono text-[11px] leading-[2]">
                <div id="tl1" class="text-db-green opacity-0">$ vite build</div>
                <div id="tl2" class="text-db-muted opacity-0">
                  ✓ 342 modules transformed
                </div>
                <div id="tl3" class="text-db-muted opacity-0">
                  ↻ rebuilding...
                </div>
                <div id="tl4" class="text-db-amber opacity-0">
                  ↻ agent re-analyzing diff...
                </div>
                <div id="tl5" class="text-db-muted opacity-0">
                  ↻ still slightly off...
                </div>
              </div>
            </div>

            <!-- ── Scene 4: live knobs ───────────────────────────────────── -->
            <div
              id="scene-4"
              class="scene absolute inset-y-0 right-0 hidden items-start justify-end p-3.5"
            >
              <div class="knob-panel">
                <div class="knob-panel-header">
                  <div class="db-panel-dot"></div>
                  Tweaks — Button
                </div>
                <div class="flex flex-col gap-2.5 p-2.5">
                  <!-- number -->
                  <div>
                    <div class="mb-1 flex justify-between">
                      <label class="knob-label">Padding</label>
                      <span id="kv-num" class="knob-value">6px</span>
                    </div>
                    <input
                      type="range"
                      id="k-num"
                      min="2"
                      max="20"
                      value="6"
                      class="m-0 w-full cursor-pointer accent-db-accent"
                    />
                  </div>

                  <!-- color -->
                  <div>
                    <div class="mb-1 flex items-center justify-between">
                      <label class="knob-label">Background</label>
                      <span id="kv-color" class="knob-value">#7c6dfa</span>
                    </div>
                    <div class="flex items-center gap-1.5">
                      <input
                        type="color"
                        id="k-color"
                        value="#7c6dfa"
                        class="h-5 w-6 cursor-pointer rounded border border-db-border bg-transparent p-px"
                      />
                      <div
                        id="kv-color-preview"
                        class="h-5 flex-1 rounded border border-db-border bg-db-accent"
                      >
                      </div>
                    </div>
                  </div>

                  <!-- text -->
                  <div>
                    <label class="knob-label mb-1 block">Label text</label>
                    <input
                      type="text"
                      id="k-text"
                      value="Action"
                      class="knob-input-base"
                    />
                  </div>

                  <!-- boolean -->
                  <div class="flex items-center justify-between">
                    <label class="knob-label">Rounded</label>
                    <label
                      class="relative inline-block h-[17px] w-[30px] cursor-pointer"
                    >
                      <input
                        type="checkbox"
                        id="k-bool"
                        checked
                        class="absolute h-0 w-0 opacity-0"
                      />
                      <span
                        id="k-bool-track"
                        class="absolute inset-0 rounded-full bg-db-accent"
                      >
                        <span
                          id="k-bool-thumb"
                          class="absolute left-0.5 top-0.5 size-[13px] rounded-full bg-white transition-transform duration-200"
                          style="transform:translateX(13px)"></span>
                      </span>
                    </label>
                  </div>

                  <!-- select -->
                  <div>
                    <label class="knob-label mb-1 block">Size</label>
                    <select
                      id="k-select"
                      class="knob-input-base cursor-pointer"
                    >
                      <option value="sm">Small</option>
                      <option value="md" selected>Medium</option>
                      <option value="lg">Large</option>
                    </select>
                  </div>

                  <!-- button-group -->
                  <div>
                    <label class="knob-label mb-1 block">Variant</label>
                    <div
                      class="flex overflow-hidden rounded-md border border-db-border"
                    >
                      <button
                        class="kb flex-1 border-r border-db-border py-0.5 text-[8px] cursor-pointer bg-[#7c6dfa22] text-db-accent"
                        data-val="primary">Primary</button
                      >
                      <button
                        class="kb flex-1 border-r border-db-border py-0.5 text-[8px] cursor-pointer bg-transparent text-db-muted"
                        data-val="secondary">Ghost</button
                      >
                      <button
                        class="kb flex-1 py-0.5 text-[8px] cursor-pointer bg-transparent text-db-muted"
                        data-val="danger">Danger</button
                      >
                    </div>
                  </div>

                  <!-- finalize -->
                  <button
                    id="k-finalize"
                    class="w-full rounded-md bg-db-accent py-1.5 text-[9px] font-semibold tracking-wider text-white transition-colors cursor-pointer"
                  >
                    Finalize ↗
                  </button>
                </div>
              </div>
            </div>

            <!-- ── Scene 5: loop diagram ─────────────────────────────────── -->
            <div
              id="scene-5"
              class="scene absolute inset-0 hidden items-center justify-center bg-db-bg/95"
            >
              <svg
                width="320"
                height="290"
                viewBox="0 0 320 290"
                fill="none"
                style="overflow:visible;"
              >
                <line
                  x1="160"
                  y1="50"
                  x2="160"
                  y2="82"
                  stroke="#7c6dfa"
                  stroke-width="1.5"
                  stroke-dasharray="4 3"
                  class="loop-line"
                  id="ll1"></line>
                <line
                  x1="160"
                  y1="112"
                  x2="160"
                  y2="142"
                  stroke="#7c6dfa"
                  stroke-width="1.5"
                  stroke-dasharray="4 3"
                  class="loop-line"
                  id="ll2"></line>
                <line
                  x1="160"
                  y1="172"
                  x2="160"
                  y2="202"
                  stroke="#7c6dfa"
                  stroke-width="1.5"
                  stroke-dasharray="4 3"
                  class="loop-line"
                  id="ll3"></line>
                <line
                  x1="160"
                  y1="232"
                  x2="160"
                  y2="258"
                  stroke="#4ade80"
                  stroke-width="1.5"
                  stroke-dasharray="4 3"
                  class="loop-line"
                  id="ll4"></line>
                <g class="loop-node" id="ln1">
                  <rect
                    x="55"
                    y="20"
                    width="210"
                    height="30"
                    rx="6"
                    fill="#13131a"
                    stroke="#7c6dfa"
                    stroke-width="1.5"></rect>
                  <text
                    x="160"
                    y="39"
                    text-anchor="middle"
                    fill="#e2e2f0"
                    font-size="11"
                    font-family="Inter,sans-serif"
                    font-weight="500">You annotate</text
                  >
                </g>
                <g class="loop-node" id="ln2">
                  <rect
                    x="35"
                    y="82"
                    width="250"
                    height="30"
                    rx="6"
                    fill="#13131a"
                    stroke="#1e1e2e"
                    stroke-width="1"></rect>
                  <text
                    x="160"
                    y="101"
                    text-anchor="middle"
                    fill="#a0a0b8"
                    font-size="10"
                    font-family="Inter,sans-serif"
                    >Agent reads full context</text
                  >
                </g>
                <g class="loop-node" id="ln3">
                  <rect
                    x="35"
                    y="142"
                    width="250"
                    height="30"
                    rx="6"
                    fill="#13131a"
                    stroke="#1e1e2e"
                    stroke-width="1"></rect>
                  <text
                    x="160"
                    y="161"
                    text-anchor="middle"
                    fill="#a0a0b8"
                    font-size="10"
                    font-family="Inter,sans-serif">Agent creates tweaks</text
                  >
                </g>
                <g class="loop-node" id="ln4">
                  <rect
                    x="55"
                    y="202"
                    width="210"
                    height="30"
                    rx="6"
                    fill="#13131a"
                    stroke="#1e1e2e"
                    stroke-width="1"></rect>
                  <text
                    x="160"
                    y="221"
                    text-anchor="middle"
                    fill="#a0a0b8"
                    font-size="10"
                    font-family="Inter,sans-serif"
                    >You pick what looks right</text
                  >
                </g>
                <g class="loop-node" id="ln5">
                  <rect
                    x="25"
                    y="258"
                    width="270"
                    height="30"
                    rx="6"
                    fill="#0d1f15"
                    stroke="#4ade80"
                    stroke-width="1.5"></rect>
                  <text
                    x="160"
                    y="277"
                    text-anchor="middle"
                    fill="#4ade80"
                    font-size="10"
                    font-family="Inter,sans-serif"
                    font-weight="500">Design Bridge writes to source ✓</text
                  >
                </g>
              </svg>
            </div>
          </div><!-- /scene-container -->
        </BrowserFrame>
      </div>
    </div><!-- /story-right -->
  </div><!-- /story-inner -->
</section>

---
import Base from '../layouts/Base.astro';
import * as readme from '../../../README.md';

const html = await readme.compiledContent();
// Split on <hr> — each `---` in the README becomes a section boundary.
// sections[0] = hero (h1 + intro), sections[1] = how it works, sections[2+] = rest
const sections = html.split(/<hr\s*\/?>/);
const [heroSection, howItWorksSection, ...docsSections] = sections;
---

<Base>
  <header class="hero">
    <div class="hero-inner">
      <div class="hero-glow"></div>
      <div class="hero-content">
        <Fragment set:html={heroSection} />
        <div class="hero-cta">
          <a href="#setup" class="wa-button wa-accent wa-brand">Get started ↓</a>
          <a
            href="https://github.com/nicholasgasior/ui-bridge"
            target="_blank"
            rel="noopener"
            class="wa-button wa-outlined wa-neutral">GitHub ↗</a
          >
        </div>
      </div>
    </div>
  </header>

  <section class="how-it-works-band">
    <div class="band-inner">
      <Fragment set:html={howItWorksSection} />
    </div>
  </section>

  <main class="docs-content wa-stack">
    {docsSections.map((section) => <Fragment set:html={section} />)}
  </main>
</Base>

---
import Base from '../layouts/Base.astro';
import * as readme from '../../../README.md';

const html = await readme.compiledContent();
// Split on <hr> — each `---` in the README becomes a zone boundary.
// zones[0] = hero (h1 + tagline)
// zones[1] = why UI Bridge (3 feature highlights)
// zones[2] = how it works
// zones[3] = setup (install + connect agent)
// zones[4] = documentation (config reference + license)
const [heroSection, whySection, howItWorksSection, setupSection, configSection, faqSection] =
  html.split(/<hr\s*\/?>/);
---

<Base>
  <header class="hero">
    <div class="hero-inner">
      <div class="hero-glow"></div>
      <div class="hero-content">
        <Fragment set:html={heroSection} />
        <div class="hero-cta">
          <a href="#setup" class="wa-button wa-accent wa-brand">Get started ↓</a>
          <a
            href="https://github.com/mariohamann/ui-bridge"
            target="_blank"
            rel="noopener"
            class="wa-button wa-outlined wa-neutral">GitHub ↗</a
          >
        </div>
      </div>
    </div>
  </header>

  <section class="why-band">
    <div class="why-inner">
      <Fragment set:html={whySection} />
    </div>
  </section>

  <section class="how-it-works-band">
    <div class="band-inner">
      <Fragment set:html={howItWorksSection} />
    </div>
  </section>

  <script src="../scripts/how-it-works.ts"></script>
  <script src="../scripts/demo-comments.ts"></script>

  <section id="setup" class="setup-band">
    <div class="setup-inner">
      <Fragment set:html={setupSection} />
    </div>
  </section>

  <section class="config-reference-band">
    <div class="config-inner">
      <Fragment set:html={configSection} />
    </div>
  </section>

  <section class="faq-band">
    <div class="faq-inner">
      <Fragment set:html={faqSection} />
    </div>
  </section>
</Base>
